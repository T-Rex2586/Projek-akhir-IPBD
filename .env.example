# ============================================
# Crypto Pipeline — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database (PostgreSQL) ──────────────────────
DB_HOST=localhost
DB_PORT=5435
DB_NAME=crypto_pipeline
DB_USER=postgres
DB_PASSWORD=postgres

# ── MongoDB ────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=crypto_pipeline

# ── API Security ───────────────────────────────
# Generate a random key: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=your-secret-key-here
API_KEY=your-api-key-here

# ── Kafka ──────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MinIO (Bronze Layer Object Storage) ────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword
MINIO_SECURE=False
MINIO_BRONZE_BUCKET=bronze-crypto

# ── Telegram Bot Alerts ────────────────────────
# 1. Create a bot via @BotFather on Telegram
# 2. Get your chat_id via @userinfobot or @RawDataBot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
