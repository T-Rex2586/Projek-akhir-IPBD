# ============================================
# Crypto Pipeline — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database (PostgreSQL) ──────────────────────
DB_HOST=localhost
DB_PORT=5435
DB_NAME=crypto_pipeline
DB_USER=postgres
DB_PASSWORD=postgres

# ── MongoDB ────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=crypto_pipeline

# ── API Configuration ─────────────────────────
# Base URL used by dashboard to reach the API
API_BASE_URL=http://localhost:8001
# Port the API server listens on
API_PORT=8001

# ── API Security ───────────────────────────────
# Generate a random key: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=your-secret-key-here
API_KEY=your-api-key-here

# ── Kafka ──────────────────────────────────────
# Use 29092 for host access (mapped in docker-compose)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ── MinIO (Bronze Layer Object Storage) ────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword
MINIO_SECURE=False
MINIO_BRONZE_BUCKET=bronze-crypto

# ── Telegram Bot Alerts & Commands ────────────────────────
# 1. Create a bot via @BotFather on Telegram → get bot token
# 2. Get your chat_id via @userinfobot
# 3. Fill in both values below to enable:
#    - Auto-alerts for positive/negative news
#    - Trading signal commands (/predict)
#    - System status commands (/status)
# 4. Start bot listener: python start_telegram_bot.py
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
